{
  "appId": "com.ronda.cardgame",
  "appName": "Ronda Tahiro",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": false
  },
  "android": {
    "backgroundColor": "#030508",
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "loggingBehavior": "none",
    "buildOptions": {
      "keystorePath": "release-keystore.jks",
      "keystoreAlias": "ronda-key",
      "releaseType": "AAB"
    }
  },
  "ios": {
    "backgroundColor": "#030508",
    "contentInset": "automatic",
    "allowsLinkPreview": false,
    "scrollEnabled": false,
    "limitsNavigationsToAppBoundDomains": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "launchAutoHide": true,
      "launchFadeOutDuration": 500,
      "backgroundColor": "#030508",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true,
      "layoutName": "launch_screen",
      "useDialog": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#030508",
      "overlaysWebView": false
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark",
      "resizeOnFullScreen": true
    },
    "AdMob": {
      "appId": "ca-app-pub-1725525147318224~6321541009",
      "appIdAndroid": "ca-app-pub-1725525147318224~6321541009",
      "appIdIos": "ca-app-pub-1725525147318224~6321541009",
      "initializeForTesting": false,
      "tagForChildDirectedTreatment": false,
      "tagForUnderAgeOfConsent": false
    },
    "InAppPurchase2": {
      "products": [
        {"id":"ronda_coins_500",    "type":"consumable"},
        {"id":"ronda_coins_1200",   "type":"consumable"},
        {"id":"ronda_coins_2000",   "type":"consumable"},
        {"id":"ronda_coins_3000",   "type":"consumable"},
        {"id":"ronda_coins_5000",   "type":"consumable"},
        {"id":"ronda_coins_9000",   "type":"consumable"},
        {"id":"ronda_coins_13000",  "type":"consumable"},
        {"id":"ronda_coins_20000",  "type":"consumable"},
        {"id":"ronda_coins_30000",  "type":"consumable"},
        {"id":"ronda_coins_50000",  "type":"consumable"},
        {"id":"ronda_coins_80000",  "type":"consumable"},
        {"id":"ronda_coins_120000", "type":"consumable"},
        {"id":"ronda_coins_200000", "type":"consumable"},
        {"id":"ronda_bundle_rondag","type":"consumable"},
        {"id":"ronda_bundle_hero",  "type":"consumable"},
        {"id":"ronda_bundle_vip",   "type":"consumable"},
        {"id":"ronda_bundle_season","type":"consumable"},
        {"id":"ronda_deal_daily",   "type":"consumable"}
      ]
    }
  }
}