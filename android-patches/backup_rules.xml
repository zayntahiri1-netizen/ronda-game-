<?xml version="1.0" encoding="utf-8"?>
<!--
  Ronda Tahiro - Backup Rules
  يمنع النسخ الاحتياطي لبيانات حساسة (مفاتيح API، جلسات المستخدم)
-->
<full-backup-content>
    <!-- استثناء ملفات الإعدادات الحساسة من النسخ الاحتياطي -->
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
</full-backup-content>
