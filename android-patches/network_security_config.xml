<?xml version="1.0" encoding="utf-8"?>
<!--
  رونداة - Android Network Security Config
  يسمح بالاتصال الآمن بجميع الخوادم المطلوبة
-->
<network-security-config>
    <!-- Trust system CAs for secure connections -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- Allowed domains -->
    <domain-config cleartextTrafficPermitted="false">
        <!-- Firebase -->
        <domain includeSubdomains="true">firebaseapp.com</domain>
        <domain includeSubdomains="true">firebase.google.com</domain>
        <domain includeSubdomains="true">firebaseio.com</domain>
        <domain includeSubdomains="true">googleapis.com</domain>

        <!-- Supabase -->
        <domain includeSubdomains="true">supabase.co</domain>
        <domain includeSubdomains="true">supabase.in</domain>

        <!-- Ably -->
        <domain includeSubdomains="true">ably.io</domain>
        <domain includeSubdomains="true">realtime.ably.io</domain>
        <domain includeSubdomains="true">rest.ably.io</domain>

        <!-- PayPal -->
        <domain includeSubdomains="true">paypal.com</domain>
        <domain includeSubdomains="true">paypalobjects.com</domain>

        <!-- Google Fonts -->
        <domain includeSubdomains="true">fonts.googleapis.com</domain>
        <domain includeSubdomains="true">fonts.gstatic.com</domain>

        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>
</network-security-config>
